  "conversaciones": [
    {
      "titulo": "PRESENTACIÓN TRABAJO",
      "frases": [
        {"autor": "jefe", "es": "Buenos días. Este es el señor Adrián.", "jp": "Ohayou gozaimasu. Kochira wa Adrian-san desu"},
        {"autor": "yo", "es": "Encantado de conocerte. Soy de España. Mucho gusto.", "jp": "Hajimemashite. Supein kara kimashita. Douzo yoroshiku"},
        {"autor": "compañero", "es": "Mucho gusto, soy Tanaka. Bienvenido.", "jp": "Tanaka desu. Douzo yoroshiku. Irasshai"},
        {"autor": "yo", "es": "Muchas gracias. Perdón, ¿dónde está mi mesa?", "jp": "Arigatou gozaimasu. Sumimasen, watashi no tsukue wa doko desu ka"}
      ]
    },
    {
      "titulo": "QUEDANDO AMIGOS",
      "frases": [
        {"autor": "amigo", "es": "Adrián, ¿qué vas a hacer mañana?", "jp": "Adrian-san, ashita nani o shimasu ka"},
        {"autor": "yo", "es": "Voy a ir a Akihabara con un amigo.", "jp": "Tomodachi to Akihabara e ikimasu"},
        {"autor": "amigo", "es": "¿A qué hora vas a ir?", "jp": "Nanji ni ikimasu ka"},
        {"autor": "yo", "es": "Voy a ir a las diez de la mañana.", "jp": "Gozen juuji ni ikimasu"},
        {"autor": "amigo", "es": "Entiendo. ¡Pásalo bien!", "jp": "Wakarimashita. Tanoshinde kudasai"}
      ]
    },
    {
      "titulo": "EN UN IZAKAYA",
      "frases": [
        {"autor": "yo", "es": "Perdone, tráigame el menú por favor.", "jp": "Sumimasen, menyuu o onegaishimasu"},
        {"autor": "camarero", "es": "Sí, aquí tiene. ¿Qué desea beber?", "jp": "Hai, douzo. Nani o nomimasu ka"},
        {"autor": "yo", "es": "Dos cervezas y un té verde por favor.", "jp": "Biiru o futatsu to ocha o onegaishimasu"},
        {"autor": "camarero", "es": "Entendido. ¿Y de comer?", "jp": "Wakarimashita. Otabemono wa"},
        {"autor": "yo", "es": "Yakitori por favor. ¿Cuánto cuesta todo?", "jp": "Yakitori o onegaishimasu. Zenbu de ikura desu ka"}
      ]
    },
    {
      "titulo": "SUPERMERCADO",
      "frases": [
        {"autor": "yo", "es": "Perdone, ¿dónde está la leche?", "jp": "Sumimasen, gyuunyuu wa doko desu ka"},
        {"autor": "empleado", "es": "Está allí, al lado del pan.", "jp": "Asoko desu. Pan no tonari desu"},
        {"autor": "yo", "es": "Muchas gracias. ¿Tiene bolsas?", "jp": "Arigatou gozaimasu. Fukuro wa arimasu ka"},
        {"autor": "empleado", "es": "Sí, cuestan cinco yenes.", "jp": "Hai, go-en desu"},
        {"autor": "yo", "es": "Está bien, póngame una por favor.", "jp": "Wakarimashita. Hitotsu onegaishimasu"}
      ]
    },
    {
      "titulo": "HABLANDO TELÉFONO",
      "frases": [
        {"autor": "yo", "es": "Diga, ¿es la casa del señor Tanaka?", "jp": "Moshimoshi, Tanaka-san no otaku desu ka"},
        {"autor": "tanaka", "es": "Sí, soy Tanaka. ¡Hola Adrián!", "jp": "Hai, Tanaka desu. Adrian-san, konnichiwa"},
        {"autor": "yo", "es": "Hola. ¿Quieres ir al cine este domingo?", "jp": "Konnichiwa. Konshuu no nichiyoubi ni eiga o mimasen ka"},
        {"autor": "tanaka", "es": "Lo siento, el domingo estoy ocupado.", "jp": "Sumimasen, nichiyoubi wa chotto isogashii desu"},
        {"autor": "yo", "es": "Ah, entiendo. Entonces, hasta la próxima.", "jp": "Aa, wakarimashita. Mata kondo"}
      ]
    },
    {
      "titulo": "PIDIENDO DIRECCIÓN",
      "frases": [
        {"autor": "yo", "es": "Buenas tardes, soy Adrián, soy extranjero y me gustaría saber dónde está la estación por favor.", "jp": "Konbanwa, Adrian desu. Gaikokujin desu ga, eki wa doko desu ka. Onegaishimasu"},
        {"autor": "meruem", "es": "Buenas tardes, soy Meruem. Esa estación está al final de esta calle.", "jp": "Konbanwa, Meruem desu. Sono eki wa kono michi no saki ni arimasu"}
      ]
    }
  ]
}
